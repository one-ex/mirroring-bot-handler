language = "python"
modules = ["python-3.11"]

[packager]
after = ["pip", "install", "-r", "requirements.txt"]

[workflows]
runButton = "run Workflow"

[[workflows.workflow]]
name = "run Workflow"
mode = "sequential"
author = 55537756

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn bot:app --host 0.0.0.0 --port 8080"

[agent]
expertMode = true

[[ports]]
localPort = 8080
externalPort = 80
